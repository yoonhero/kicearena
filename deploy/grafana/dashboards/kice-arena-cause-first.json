  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Incident score",
      "description": "장애 원인별 점수를 가중 합산한 0-100 점수입니다. 5xx, 지연, event loop, 메모리 증가, FD, socket orphan, room stale 신호를 함께 봅니다.",
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 40
              },
              {
                "color": "red",
                "value": 70
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true,
        "showPercentChange": true
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "$datasource"
          },
          "expr": "(0.22 * (100 * clamp_max(((sum(rate(kice_arena_http_request_duration_seconds_count{status=~\"5..\"}[5m])) or vector(0)) / clamp_min((sum(rate(kice_arena_http_request_duration_seconds_count[5m])) or vector(0)), 1)) / 0.05, 1)) + 0.18 * (100 * clamp_max((histogram_quantile(0.95, sum by (le) (rate(kice_arena_http_request_duration_seconds_bucket[5m]))) or vector(0)) / 1.0, 1)) + 0.18 * (100 * clamp_max((max(kice_arena_nodejs_eventloop_lag_p99_seconds) or vector(0)) / 0.25, 1)) + 0.14 * (100 * clamp_max((sum(clamp_min(deriv(kice_arena_process_resident_memory_bytes[15m]) * 900, 0)) or vector(0)) / 209715200, 1)) + 0.10 * (100 * clamp_max(((sum(kice_arena_process_open_fds) or vector(0)) / clamp_min((sum(kice_arena_process_max_fds) or vector(0)), 1)) / 0.80, 1)) + 0.08 * (100 * clamp_max(((clamp_min((sum(kice_arena_socket_connections) or vector(0)) - (sum(kice_arena_players{state=\"connected\"}) or vector(0)), 0)) / clamp_min((sum(kice_arena_socket_connections) or vector(0)), 1)) / 0.10, 1)) + 0.05 * (clamp_max((100 * (max(kice_arena_room_disconnect_risk_score) or vector(0))), 100)) + 0.05 * (clamp_max((100 * (max(kice_arena_room_cleanup_pressure_score) or vector(0))), 100)))",
          "refId": "A"
        }
      ]
    },
